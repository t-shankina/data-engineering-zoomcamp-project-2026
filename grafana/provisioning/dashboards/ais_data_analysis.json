          "pluginVersion": "4.15.0",
          "queryType": "table",
          "rawSql": "SELECT\n  CASE\n    WHEN navigational_status = 0 THEN 'Under way using engine'\n    WHEN navigational_status = 1 THEN 'At anchor'\n    WHEN navigational_status = 2 THEN 'Not under command'\n    WHEN navigational_status = 3 THEN 'Restricted manoeuverability'\n    WHEN navigational_status = 4 THEN 'Constrained by her draught'\n    WHEN navigational_status = 5 THEN 'Moored'\n    WHEN navigational_status = 6 THEN 'Aground'\n    WHEN navigational_status = 7 THEN 'Engaged in Fishing'\n    WHEN navigational_status = 8 THEN 'Under way sailing'\n    WHEN navigational_status = 14 THEN 'AIS-SART is active'\n    ELSE 'Not defined'\n  END AS navigational_status,\n  COUNT(*) AS vessel_cnt\nFROM ais_db.vessel_last_position\nWHERE last_seen_at >= now() - INTERVAL 1 HOUR\nGROUP BY navigational_status;\n",
          "refId": "A"
        }
